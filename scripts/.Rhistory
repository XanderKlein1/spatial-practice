intestine
#Create plot of tissue image
SpatialDimPlot(intestine, alpha = c(0,0), image.alpha = 1) + NoLegend()
#Create plot of tissue image
SpatialDimPlot(intestine, images = "tissue_hires_image.png", alpha = c(0,0), image.alpha = 1) + NoLegend()
#Create plot of tissue image
